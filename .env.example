# Copy to .env.local before running the app.

# App URL
APP_URL="http://localhost:3000"

# Prisma -> Supabase Postgres
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# App admin promotion allowlist
ADMIN_EMAILS="your_admin_email@example.com"

# Gmail SMTP notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your_smtp_email@gmail.com"
SMTP_PASS="your_smtp_app_password"
MAIL_FROM="Your Name <your_smtp_email@gmail.com>"

# Twilio WhatsApp Sandbox
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_SANDBOX_MODE="true"

# Optional business/admin WhatsApp alert recipient
TWILIO_ADMIN_WHATSAPP_TO="whatsapp:+1234567890"
